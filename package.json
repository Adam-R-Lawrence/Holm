{
  "name": "holm-site",
  "private": true,
  "scripts": {
    "build:css": "sass --style=compressed --no-source-map styles/scss/main.scss styles/styles.min.css",
    "check:css": "tmp=$(mktemp) && sass --style=compressed --no-source-map styles/scss/main.scss \"$tmp\" && cmp -s \"$tmp\" styles/styles.min.css; status=$?; rm -f \"$tmp\"; exit $status",
    "lint": "eslint --no-error-on-unmatched-pattern \"javascript/**/*.js\" \"tests/e2e/**/*.js\" \"playwright.config.js\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "dev": "vite --host 127.0.0.1 --port 4173"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.50.1",
    "eslint": "^9.19.0",
    "globals": "^15.14.0",
    "sass": "^1.100.0",
    "vite": "^7.3.1"
  }
}
